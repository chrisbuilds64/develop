# Tweight Core - Docker Deployment Environment Variables
# Copy this file to .env on the server

# Environment mode (development = mock auth, production = Clerk)
ENV=development

# UC-003: Clerk Authentication (not used in development mode)
CLERK_SECRET_KEY=***REMOVED***
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=***REMOVED***

# Note: DATABASE_URL is set in docker-compose.yml
